# Copy to `.env` before `docker compose up --build`
#   cp .env.docker.example .env

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taxi
POSTGRES_PORT=5432
APP_PORT=3000

# Required — use a long random string in real environments
JWT_SECRET=change-me-to-a-long-random-string

# Public URL of this deployment (used for PayPal returns, absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# First boot only: seed demo admin (ops@transfers.co / admin123) + sample data
SEED_ON_START=true

# Optional — Web Push (npx web-push generate-vapid-keys)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@transfers.co

# Optional — Stripe / PayPal (or configure later in Admin → Settings)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox
