DATABASE_URL="postgresql://postgres:postgres@localhost:5433/taxi?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"

# ── Docker ──────────────────────────────────────────────────────────────────
# Quick start on a new machine:
#   cp .env.docker.example .env
#   docker compose up --build
# App: http://localhost:3000  |  DB: localhost:5432
# Dev hot-reload instead:
#   docker compose -f docker-compose.dev.yml up --build
# See .env.docker.example for Postgres / seed / VAPID / payment vars.

# Google Maps (optional — only if you re-enable free-text Places autocomplete)
# Booking /book uses service zones from the database for pickup/destination.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Stripe (optional — can also be set in Admin → Settings → Payments)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# PayPal (optional — can also be set in Admin → Settings → Payments)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox

# Public site URL used for PayPal return/cancel redirects (and similar).
# Local: http://localhost:3000
# ngrok: https://your-subdomain.ngrok-free.dev
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push — staff alerts on desktop + mobile browsers (admin + driver).
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@transfers.co
